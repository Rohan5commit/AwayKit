# AwayKit Environment Configuration
# Copy this file to .env and fill in your values

# QVAC Configuration
# QVAC_MODEL=LLAMA_3_2_1B_INST_Q4_0
# QVAC_FALLBACK_MODE=true

# Pears P2P Configuration
# PEARS_TOPIC_PREFIX=awaykit
# PEARS_DISCOVERY_TIMEOUT=30000

# WDK Wallet Configuration
# WDK_NETWORK=tron
# WDK_RPC_URL=https://nile.trongrid.io
# WDK_DEFAULT_CURRENCY=USDT

# Development
# VITE_APP_TITLE=AwayKit
# VITE_DEMO_MODE=false
